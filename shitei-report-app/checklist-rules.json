{
  "version": 1,
  "categories": {
    "overview": { "ids": ["ov1", "ov2", "ov3", "ov4", "ov5"], "group": "cases", "title": "5症例の構成確認" },
    "c1": { "ids": ["c1a", "c1b", "c1c", "c1d", "c1e"], "group": "cases", "title": "第1症例：F0" },
    "c2": { "ids": ["c2a", "c2b", "c2c", "c2d"], "group": "cases", "title": "第2症例：F1依存症" },
    "c3": { "ids": ["c3a", "c3b", "c3c", "c3d", "c3e"], "group": "cases", "title": "第3症例：F2" },
    "c4": { "ids": ["c4a", "c4b", "c4c", "c4d", "c4e"], "group": "cases", "title": "第4症例：F3" },
    "c5": { "ids": ["c5a", "c5b", "c5c", "c5d"], "group": "cases", "title": "第5症例：F4-F9" },
    "adm": { "ids": ["adm1", "adm2", "adm3", "adm4", "adm5", "adm6"], "group": "adm", "title": "入院形態要件" },
    "timing": { "ids": ["t1", "t2", "t3", "t4", "t5", "t6"], "group": "timing", "title": "診療期間条件" },
    "common": { "ids": ["cm1", "cm2", "cm3", "cm4", "cm5", "cm6", "cm7", "cm8", "cm9", "cm10", "cm11", "cm12", "cm13", "cm14", "cm15"], "group": "com", "title": "共通記載要件" }
  },
  "rules": [
    { "id": "ov1", "label": "第1症例：F0（器質性精神障害）の症例を確保", "ruleType": "auto", "evaluator": "icdCategory", "caseNum": 1, "icdRange": "F0" },
    { "id": "ov2", "label": "第2症例：F1依存症の症例を確保", "ruleType": "auto", "evaluator": "icdCategory", "caseNum": 2, "icdRange": "F1" },
    { "id": "ov3", "label": "第3症例：F2の症例を確保", "ruleType": "auto", "evaluator": "icdCategory", "caseNum": 3, "icdRange": "F2" },
    { "id": "ov4", "label": "第4症例：F3の症例を確保", "ruleType": "auto", "evaluator": "icdCategory", "caseNum": 4, "icdRange": "F3" },
    { "id": "ov5", "label": "第5症例：F4-F9の症例を確保", "ruleType": "auto", "evaluator": "icdCategory", "caseNum": 5, "icdRange": "F4F9" },
    { "id": "c1a", "label": "ICD-10がF00-F09（老年期認知症除く）", "ruleType": "auto", "evaluator": "icdInRange", "caseNum": 1, "min": 0, "max": 9, "prefix": "F0" },
    { "id": "c1b", "label": "主評価入院形態が措置または医療保護", "ruleType": "auto", "evaluator": "admTypeValid", "caseNum": 1 },
    { "id": "c1c", "label": "身体的背景と精神症状の関連を記載", "ruleType": "semi", "evaluator": "fieldFilled", "caseNum": 1, "fields": ["s4_other", "s5_dx_basis"] },
    { "id": "c1d", "label": "器質性疾患との鑑別根拠を記載", "ruleType": "semi", "evaluator": "fieldFilled", "caseNum": 1, "fields": ["s5_diff_dx"] },
    { "id": "c1e", "label": "（特例）3ヶ月以内転院の確認", "ruleType": "manual", "manualHint": "3ヶ月以内転院の特例該当時は事務取扱要領を確認し、必要に応じて別途説明を添付してください。" },
    { "id": "c2a", "label": "依存症候群（F1x.2以上）である", "ruleType": "auto", "evaluator": "icdDependency", "caseNum": 2 },
    { "id": "c2b", "label": "主評価入院形態が措置または医療保護", "ruleType": "auto", "evaluator": "admTypeValid", "caseNum": 2 },
    { "id": "c2c", "label": "依存症経過・離脱症状を記載", "ruleType": "semi", "evaluator": "fieldFilled", "caseNum": 2, "fields": ["s3_admission", "s3_course"] },
    { "id": "c2d", "label": "（特例）転院3ヶ月以内の確認", "ruleType": "manual", "manualHint": "転院から3ヶ月以内の特例該当時は事務取扱要領を確認し、必要に応じて別途説明を添付してください。" },
    { "id": "c3a", "label": "診断がF20-F29", "ruleType": "auto", "evaluator": "icdInRange", "caseNum": 3, "min": 20, "max": 29, "prefix": "F2" },
    { "id": "c3b", "label": "主評価入院形態が措置または医療保護", "ruleType": "auto", "evaluator": "admTypeValid", "caseNum": 3 },
    { "id": "c3c", "label": "陽性・陰性症状を体系的に記載", "ruleType": "semi", "evaluator": "fieldFilled", "caseNum": 3, "fields": ["s4_thought", "s4_perception"] },
    { "id": "c3d", "label": "F20診断基準への対応を記載", "ruleType": "semi", "evaluator": "fieldFilled", "caseNum": 3, "fields": ["s5_dx_basis"] },
    { "id": "c3e", "label": "鑑別診断と除外根拠を記載", "ruleType": "semi", "evaluator": "fieldFilled", "caseNum": 3, "fields": ["s5_diff_dx"] },
    { "id": "c4a", "label": "診断がF30-F39", "ruleType": "auto", "evaluator": "icdInRange", "caseNum": 4, "min": 30, "max": 39, "prefix": "F3" },
    { "id": "c4b", "label": "主評価入院形態が措置または医療保護", "ruleType": "auto", "evaluator": "admTypeValid", "caseNum": 4 },
    { "id": "c4c", "label": "自殺リスク評価を具体的に記載", "ruleType": "semi", "evaluator": "fieldFilled", "caseNum": 4, "fields": ["s4_risk"] },
    { "id": "c4d", "label": "統合失調症・器質性との鑑別を記載", "ruleType": "semi", "evaluator": "fieldFilled", "caseNum": 4, "fields": ["s5_diff_dx"] },
    { "id": "c4e", "label": "薬物療法の選択根拠と経過を記載", "ruleType": "semi", "evaluator": "fieldFilled", "caseNum": 4, "fields": ["s7_pharma"] },
    { "id": "c5a", "label": "診断がF40-F98", "ruleType": "auto", "evaluator": "icdInRange", "caseNum": 5, "min": 40, "max": 98, "prefix": "F4F9" },
    { "id": "c5b", "label": "主評価入院形態が措置または医療保護", "ruleType": "auto", "evaluator": "admTypeValid", "caseNum": 5 },
    { "id": "c5c", "label": "18歳未満の場合の発達歴・連携記載", "ruleType": "manual", "manualHint": "18歳未満の場合、Step2 生活歴・Step4 精神症状に発達段階・養育環境・支援連携を追記してください。" },
    { "id": "c5d", "label": "F6の場合のAxis II的評価", "ruleType": "manual", "manualHint": "F6 パーソナリティ障害の場合、Axis II 的評価と ICD/DSM の対応を Step5 診断根拠に記載してください。" },
    { "id": "adm1", "label": "措置入院を主評価とする症例が1例以上", "ruleType": "auto", "evaluator": "admCount", "admType": "措置入院", "minCount": 1 },
    { "id": "adm2", "label": "医療保護入院を主評価とする症例が1例以上", "ruleType": "auto", "evaluator": "admCount", "admType": "医療保護入院", "minCount": 1 },
    { "id": "adm3", "label": "医療保護で入院時から担当・立会い1例以上", "ruleType": "manual", "manualHint": "5症例のうち1例は医療保護で入院時から担当・立会いが必要です。該当症例の Step1 入院形態・Step3 入院時状況を確認してください。" },
    { "id": "adm4", "label": "任意入院への形態変更後も治療した症例", "ruleType": "manual", "manualHint": "任意入院へ形態変更後も治療した症例が必要です。該当症例の入院後経過・Step5 法的根拠を確認してください。" },
    { "id": "adm5", "label": "退院後通院治療（1ヶ月以上）を行った症例", "ruleType": "semi", "evaluator": "anyFieldFilled", "fields": ["s7_aftercare"] },
    { "id": "adm6", "label": "行動制限を実施した症例が含まれる", "ruleType": "auto", "evaluator": "anyRestriction" },
    { "id": "t1", "label": "5症例すべてが申請日から7年以内", "ruleType": "semi", "evaluator": "withinYears", "years": 7 },
    { "id": "t2", "label": "申請前1年以内に診療開始した症例が1例以上", "ruleType": "semi", "evaluator": "withinYearsFromApp", "years": 1, "minCount": 1 },
    { "id": "t3", "label": "申請1年前より前に診療開始した症例が2例以上", "ruleType": "semi", "evaluator": "beforeYearsFromApp", "years": 1, "minCount": 2 },
    { "id": "t4", "label": "各症例で入院から退院まで継続担当", "ruleType": "manual", "manualHint": "各症例で入院から退院まで継続担当したか、表紙 ⑦-1 と本文の記載から確認してください。" },
    { "id": "t5", "label": "精神病床を有する医療機関での常時勤務下で担当", "ruleType": "manual", "manualHint": "精神病床を有する医療機関での常時勤務下で担当したかを確認してください。" },
    { "id": "t6", "label": "指導医が同じ医療機関の常時勤務指定医として指導", "ruleType": "manual", "manualHint": "指導医が同一医療機関の常時勤務指定医として指導したか。Step1 指導医欄と様式 ⑦-3 自筆署名を確認してください。" },
    { "id": "cm1", "label": "令和7年1月版様式3-1を使用", "ruleType": "manual", "manualHint": "提出は令和7年1月版様式3-1を使用してください（本アプリ出力は準拠下書きです）。" },
    { "id": "cm2", "label": "申請者氏名が自筆署名", "ruleType": "manual", "manualHint": "様式3-1 ① 申請者自筆署名はソフト入力不可です。印刷後に手書きしてください。" },
    { "id": "cm3", "label": "最終診断名とICD-10（F以下2桁）", "ruleType": "auto", "evaluator": "allCasesField", "field": "s1_icd" },
    { "id": "cm4", "label": "主評価入院形態を措置/医療保護から選択", "ruleType": "auto", "evaluator": "allCasesAdmValid" },
    { "id": "cm5", "label": "患者イニシャルと生年月日", "ruleType": "auto", "evaluator": "allCasesFields", "fields": ["s1_initial", "s1_dob"] },
    { "id": "cm6", "label": "入退院年月日が記載", "ruleType": "auto", "evaluator": "allCasesFields", "fields": ["s1_admit_date", "s1_discharge_date"] },
    { "id": "cm7", "label": "指導医氏名・番号・期間・署名", "ruleType": "semi", "evaluator": "allCasesField", "field": "s1_supervisor" },
    { "id": "cm8", "label": "行動制限の有無チェック", "ruleType": "auto", "evaluator": "allCasesRestrictionSet" },
    { "id": "cm9", "label": "法的手続チェックリスト記入", "ruleType": "manual", "manualHint": "様式3-1「関係法規に定める手続への対応」欄に✓を記入してください。Step6 の確認リストを参照。" },
    { "id": "cm10", "label": "退院後生活環境相談員の選任記載", "ruleType": "semi", "evaluator": "anyFieldFilled", "fields": ["s6_seisanin"] },
    { "id": "cm11", "label": "本文1200-2500字", "ruleType": "auto", "evaluator": "allCasesCharCount" },
    { "id": "cm12", "label": "入院時状況に法的要件に基づく必要性記載", "ruleType": "semi", "evaluator": "allCasesField", "field": "s3_admission" },
    { "id": "cm13", "label": "行動制限詳細（実施時）", "ruleType": "semi", "evaluator": "restrictionDetailIfNeeded" },
    { "id": "cm14", "label": "本文中に関係条文の引用なし", "ruleType": "manual", "manualHint": "本文中に関係条文の逐条引用は不可です。要件は自分の言葉で記載してください。" },
    { "id": "cm15", "label": "5症例原本（自筆署名あり）提出準備", "ruleType": "manual", "manualHint": "5症例すべての原本（自筆署名付き）の提出準備ができているか確認してください。" }
  ]
}
