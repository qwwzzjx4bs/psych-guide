{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "指定医レポート作成",
  "version": "1.4.0",
  "identifier": "com.ryotatakei.shitei-report-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "指定医レポート作成",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "shortDescription": "精神保健指定医 指定医レポート作成支援",
    "longDescription": "令和7年新基準の5症例ケースレポート（様式3-1）作成支援。保存・チェック・docx出力に対応。",
    "publisher": "指定医レポート作成",
    "copyright": "Copyright © 2026",
    "externalBin": [
      "binaries/generate_docx"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Japanese"],
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "指定医レポート作成",
        "installerHooks": "windows/installer-hooks.nsh"
      }
    }
  }
}
