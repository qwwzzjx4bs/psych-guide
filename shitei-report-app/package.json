{
  "name": "shitei-report-app",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:sidecar": "bash scripts/build-sidecar.sh",
    "build:sidecar:win": "powershell -ExecutionPolicy Bypass -File scripts/build-sidecar.ps1",
    "build:win": "npm run build:sidecar:win && npm run tauri build",
    "package:win": "powershell -ExecutionPolicy Bypass -File scripts/package-windows-release.ps1",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
