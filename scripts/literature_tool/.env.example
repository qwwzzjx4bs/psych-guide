# ============================================================
# 精神医学論文ツール — 環境変数設定例
# .env.example をコピーして .env として使用してください
# ============================================================

# ----- NCBI PubMed -----
NCBI_API_KEY=                   # https://www.ncbi.nlm.nih.gov/account/ で取得（任意, 10req/s）

# ----- Database -----
DATABASE_URL=sqlite+aiosqlite:///./data/literature.db

# ----- SMTP メール通知（Phase 3） -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_FROM_ADDRESS=your-email@gmail.com

# ----- OpenAI API（AI要約 Phase 3） -----
OPENAI_API_KEY=                 # https://platform.openai.com/ で取得
OPENAI_MODEL=gpt-4o-mini        # gpt-4o-mini を推奨（コスト抑制）

# ----- Application -----
APP_ENV=development             # development | production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,https://qwwzzjx4bs.github.io

# ----- Scheduler -----
FETCH_INTERVAL_HOURS=6          # クロール間隔（時間）
